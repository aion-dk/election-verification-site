{
  "name": "election-verification-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:docker": "vite --force --host",
    "build": "yarn type-check && yarn build-only",
    "preview": "vite preview",
    "test:unit": "vitest --environment jsdom --root src/",
    "test:unit:ci": "vitest --environment jsdom --root src/ --passWithNoTests --reporter dot --reporter junit --outputFile test-results/vitest.xml",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --output test-results/artifacts",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "prettier:ci": "npx prettier -c ./",
    "prettier": "npx prettier -w ./",
    "lint": "eslint ./src/**/*.{ts,mts,tsx,vue} --fix",
    "lint:ci": "eslint ./src/**/*.{ts,mts,tsx,vue}"
  },
  "dependencies": {
    "@assemblyvoting/electa-ui": "^5.6.6",
    "@assemblyvoting/js-client": "^6.5.0",
    "axios": "^1.18.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jsdom": "^28.1.0",
    "pdf-lib": "^1.17.1",
    "pinia": "^3.0.4",
    "sass": "^1.97.3",
    "sinon": "^21.0.2",
    "vue": "3.5.38",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.0.3",
    "vue-tsc": "^3.2.5"
  },
  "devDependencies": {
    "@assemblyvoting/types": "^1.0.8",
    "@axe-core/playwright": "^4.12.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.61.1",
    "@rushstack/eslint-patch": "^1.10.5",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/eslint-plugin": "^1.1.25",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "eslint-plugin-json": "^4.0.1",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.4.2",
    "typescript": "^5.4.5",
    "vite": "^7.3.6",
    "vitest": "^4.1.0"
  },
  "resolutions": {
    "vite": "7.3.6",
    "**/vue-i18n": "11.4.6",
    "**/undici": "7.28.0"
  },
  "engines": {
    "node": ">=24.14.0",
    "npm": ">=11.9.0"
  },
  "vite": {
    "optimizeDeps": {
      "include": [
        "axios"
      ]
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
